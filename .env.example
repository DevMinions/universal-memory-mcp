# Universal Memory MCP Server — 环境变量配置
# 复制此文件为 .env 并填入你的值：cp .env.example .env

# ============ 必须 ============
# Jina API Key (嵌入 + rerank)
JINA_API_KEY=jina_xxx

# 认证 Token (HTTP 模式必须，防止未授权访问)
MCP_AUTH_TOKEN=your-secret-token-here

# ============ 可选 ============
# LLM API Key (智能提取 + 反思引擎)
# LLM_API_KEY=sk-xxx
# LLM_MODEL=openrouter/free
# LLM_BASE_URL=https://openrouter.ai/api/v1

# 数据库路径 (Docker 模式下使用卷挂载，无需修改)
# MEMORY_DB_PATH=/data/lancedb-pro

# HTTP 服务配置
# MCP_PORT=3100
# MCP_HOST=0.0.0.0
